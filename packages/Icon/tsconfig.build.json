{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./lib",
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "jsx": "react",
