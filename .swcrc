{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true
    },
    "transform": {
      "react": {
        "runtime": "classic"
      }
    },
    "target": "es2018"
  },
  "module": {
    "type": "commonjs"
  },
  "exclude": [
    ".*\\.d\\.ts$",
    ".*\\.test\\.",
    ".*\\.stories\\.",
    "node_modules"
  ]
}
